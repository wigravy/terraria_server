# Directory that stores all server runtime files.
# Default: a server_data folder next to setup.sh and start-server.sh
SERVER_DATA="./server_data"

# Label used only by start-server.sh console output.
SERVER_NAME="My tModLoader Server"

# Steam app ID used by SteamCMD to install/update tModLoader.
TML_APP_ID=1281930

# Optional Steam branch passed to SteamCMD.
# Leave empty for the latest default public branch. Example: preview
TMODLOADER_BRANCH=

# Optional tModLoader modpack name without .json.
# Leave empty to load mods from Mods/enabled.json instead.
MODPACK=

# The following official config entries are supported but always derived from SERVER_DATA:
# world=${SERVER_DATA}/Worlds/${WORLD_NAME}.wld
# worldpath=${SERVER_DATA}/Worlds
# banlist=${SERVER_DATA}/banlist.txt
# modpath=${SERVER_DATA}/Mods

# World file name without the .wld extension.
WORLD_NAME="modded-world"

# Optional world seed used only when autocreating a world.
# Leave empty for a random seed.
WORLD_SEED=

# World size for autocreate.
# Values: 1=small, 2=medium, 3=large
WORLD_SIZE=2

# World difficulty for autocreate.
# Values: 0=classic, 1=expert, 2=master, 3=journey
WORLD_DIFFICULTY=0

# Maximum player slots.
# Values: 1-255
MAX_PLAYERS=8

# TCP port the server listens on.
PORT=7777

# Server password. Leave empty for no password.
PASSWORD=

# Message of the day shown to players on join.
MOTD="Welcome to the modded server"

# Additional cheat protection.
# Values: 0=off, 1=on
SECURE=1

# Server language code used by Terraria.
# Common values: en-US, de-DE, it-IT, fr-FR, es-ES, ru-RU, zh-Hans, pt-BR, pl-PL
LANGUAGE="en-US"

# Automatically forward the port with UPnP when supported.
# Values: 0=off, 1=on
UPNP=0

# NPC stream rate. Lower values reduce enemy skipping but increase bandwidth usage.
# Values: 0 or higher, Terraria default is 60
NPCSTREAM=60

# Process priority requested by Terraria.
# Values: 0=realtime, 1=high, 2=abovenormal, 3=normal, 4=belownormal, 5=idle
PRIORITY=1

# Journey Mode permission: freeze time.
# Values: 0=locked, 1=host only, 2=everyone
JOURNEYPERMISSION_TIME_SETFROZEN=2

# Journey Mode permission: set time to dawn.
# Values: 0=locked, 1=host only, 2=everyone
JOURNEYPERMISSION_TIME_SETDAWN=2

# Journey Mode permission: set time to noon.
# Values: 0=locked, 1=host only, 2=everyone
JOURNEYPERMISSION_TIME_SETNOON=2

# Journey Mode permission: set time to dusk.
# Values: 0=locked, 1=host only, 2=everyone
JOURNEYPERMISSION_TIME_SETDUSK=2

# Journey Mode permission: set time to midnight.
# Values: 0=locked, 1=host only, 2=everyone
JOURNEYPERMISSION_TIME_SETMIDNIGHT=2

# Journey Mode permission: toggle godmode.
# Values: 0=locked, 1=host only, 2=everyone
JOURNEYPERMISSION_GODMODE=2

# Journey Mode permission: control wind strength.
# Values: 0=locked, 1=host only, 2=everyone
JOURNEYPERMISSION_WIND_SETSTRENGTH=2

# Journey Mode permission: control rain strength.
# Values: 0=locked, 1=host only, 2=everyone
JOURNEYPERMISSION_RAIN_SETSTRENGTH=2

# Journey Mode permission: change time speed.
# Values: 0=locked, 1=host only, 2=everyone
JOURNEYPERMISSION_TIME_SETSPEED=2

# Journey Mode permission: freeze rain.
# Values: 0=locked, 1=host only, 2=everyone
JOURNEYPERMISSION_RAIN_SETFROZEN=2

# Journey Mode permission: freeze wind.
# Values: 0=locked, 1=host only, 2=everyone
JOURNEYPERMISSION_WIND_SETFROZEN=2

# Journey Mode permission: increase placement range.
# Values: 0=locked, 1=host only, 2=everyone
JOURNEYPERMISSION_INCREASEPLACEMENTRANGE=2

# Journey Mode permission: change difficulty.
# Values: 0=locked, 1=host only, 2=everyone
JOURNEYPERMISSION_SETDIFFICULTY=2

# Journey Mode permission: freeze biome spread.
# Values: 0=locked, 1=host only, 2=everyone
JOURNEYPERMISSION_BIOMESPREAD_SETFROZEN=2

# Journey Mode permission: change spawn rate.
# Values: 0=locked, 1=host only, 2=everyone
JOURNEYPERMISSION_SETSPAWNRATE=2
