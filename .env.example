# Server name shown in the server list.
SERVER_NAME=My tModLoader Server

# World file name without extension.
WORLD_NAME=modded-world

# Optional Terraria seed. Leave empty for random generation.
WORLD_SEED=

# World size: 1 = small, 2 = medium, 3 = large
WORLD_SIZE=2

# Difficulty: 0 = Classic, 1 = Expert, 2 = Master, 3 = Journey
WORLD_DIFFICULTY=0

# Maximum player slots. Keep this reasonable for your server RAM/CPU.
MAX_PLAYERS=8

# Server port. Default Terraria port is 7777.
PORT=7777

# Leave empty for no password.
PASSWORD=

# Message shown to players when they join.
MOTD=Welcome to the modded server

# Install path for tModLoader server files.
INSTALL_DIR=$HOME/terraria/tmodloader

# Install path for SteamCMD.
STEAMCMD_DIR=$HOME/steamcmd

# tModLoader Steam App ID.
TML_APP_ID=1281930

TMODLOADER_BRANCH=stable

# Set to true only if you want to log in with a Steam account.
# Valid values: true, false
USE_STEAM_LOGIN=false

# Required only when USE_STEAM_LOGIN=true.
STEAM_USERNAME=

# Required only when USE_STEAM_LOGIN=true.
STEAM_PASSWORD=

# Try to download configured Workshop mods during setup.
# Valid values: true, false
DOWNLOAD_WORKSHOP_MODS=true

# Comma-separated Workshop IDs for server-required mods only.
WORKSHOP_MOD_IDS=2824688072,2824688266,2599842771,2669644269,3338554501,3316697363,2824688804,2908170107,2563309347,2831360228

# Optional comma-separated internal mod names for enabled.json generation.
# Use this if workshop downloads do not produce local .tmod files automatically.
ENABLED_MOD_NAMES=CalamityMod,CalamityModMusic,AlchemistNPCLite,BossChecklist,InnoVault,CalamityEntropy,CalValEX,SerousCommonLib,MagicStorage,ProjectTRU

# Comma-separated Workshop IDs for optional client-side mods.
OPTIONAL_CLIENT_MOD_IDS=2835214226
